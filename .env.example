# Telegram bot token from BotFather.
BOT_API_KEY=123456:ABC

# Your Telegram numeric user id. This user can query bot status in direct chat.
ADMIN_ID=1008385559

# Local development polling settings.
AUTO_DELETE_WEBHOOK=true
POLL_TIMEOUT=30

# Only LLM mode exists for business auto-replies.
# If FREE_LLM fails, the bot does not answer and does not mark the message as read.
RESPONDER_MODE=llm

# OpenAI-compatible LLM proxy. Keep FREE_LLM_MODEL=auto to use proxy-side fallback chain.
FREE_LLM_API_KEY=freellmapi-...
BASE_URL=http://155.212.217.115:3001/v1
ENDPOINT=/v1/chat/completions
FREE_LLM_MODEL=auto
# If auto routes to a broken provider, the bot tries these models in order.
FREE_LLM_FALLBACK_MODELS=auto,@cf/openai/gpt-oss-120b,@cf/qwen/qwen3-30b-a3b-fp8,DeepSeek-V3.2,DeepSeek-V3.1,@cf/deepseek-ai/deepseek-r1-distill-qwen-32b,@cf/meta/llama-4-scout-17b-16e-instruct,gpt-oss-120b,poolside/laguna-m.1:free,poolside/laguna-xs.2:free,groq/compound-mini
LLM_TIMEOUT=90
LLM_MAX_TOKENS=700

# Optional custom persona.
# By default the bot reads back_prompt.md as the system prompt.
SYSTEM_PROMPT_FILE=back_prompt.md
# LLM_SYSTEM_PROMPT=...

# Optional prefix for every successful LLM auto-reply.
REPLY_PREFIX=

# Local data file. It stores connection metadata and recent handled updates.
STATE_FILE=.data/state.json
